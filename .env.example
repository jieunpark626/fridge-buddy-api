# 환경변수 템플릿

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=
DB_USERNAME=
DB_PASSWORD=

# Claude API (https://console.anthropic.com)
CLAUDE_API_KEY=

# Naver OAuth2 (https://developers.naver.com)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# JWT (최소 32자 이상 랜덤 문자열)
JWT_SECRET=

# OAuth2 로그인 성공 후 리다이렉트 URI
OAUTH2_REDIRECT_URI=http://localhost:3000

# 쿠키 Secure 플래그 (운영: true, 로컬: false)
COOKIE_SECURE=false
