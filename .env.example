# 환경변수 템플릿

# Spring 프로파일 (dev = 개발자 로그인 엔드포인트 활성화 / 운영은 비워두기)
SPRING_PROFILES_ACTIVE=dev

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=
DB_USERNAME=
DB_PASSWORD=

# Claude API (https://console.anthropic.com)
CLAUDE_API_KEY=

# JWT (최소 32자 이상 랜덤 문자열)
JWT_SECRET=

# 토스 로그인 mTLS (토스 콘솔에서 인증서 발급 후 설정, 로컬 개발 시 비워도 됨)
APPS_IN_TOSS_MTLS_CERT_PATH=
APPS_IN_TOSS_MTLS_KEY_PATH=

# 토스 연결끊기 콜백 인증용 Basic Auth 헤더 값 (필수, 비워두면 콜백 요청이 모두 거부됨)
TOSS_CALLBACK_AUTH_HEADER=